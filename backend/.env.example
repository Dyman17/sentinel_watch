# ESP32 Camera Stream URL
ESP_STREAM_URL=http://192.168.1.100:81/stream

# HuggingFace API Configuration
HF_API_URL=https://api-inference.huggingface.co/models/facebook/detr-resnet-50
HF_TOKEN=Bearer YOUR_HUGGINGFACE_TOKEN

# Supabase Configuration (Optional - for production)
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_KEY=YOUR_SUPABASE_KEY

# NASA Satellite Image URL (optional, uses default if not specified)
NASA_IMAGE_URL=https://eoimages.gsfc.nasa.gov/images/imagerecords/57000/57730/earth_lights_lrg.jpg
